<?xml version="1.0" encoding="UTF-8"?>
<server description="Java Agent Orchestrator">

    <featureManager>
        <feature>data-1.0</feature>
        <feature>persistence-3.2</feature>
        <feature>faces-4.1</feature>
        <feature>cdi-4.1</feature>
        <feature>websocket-2.2</feature>
        <feature>concurrent-3.1</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="${default.http.port}"
                  httpsPort="9443" />

    <library id="h2Lib">
        <fileset dir="${server.config.dir}/jdbc" includes="h2*.jar" />
    </library>

    <dataSource id="DefaultDataSource" jndiName="jdbc/realEstateDS">
        <jdbcDriver libraryRef="h2Lib" />
        <properties URL="jdbc:h2:mem:realestatedb;DB_CLOSE_DELAY=-1" />
    </dataSource>

    <webApplication location="java-agent-orchestrator.war" contextRoot="/" />

    <!-- Route application INFO+ messages to console so they appear in mvn liberty:dev / liberty:run output -->
    <logging consoleLogLevel="INFO"
            consoleSource="message"
            traceSpecification="com.microsoft.build.*=info" />

</server>
