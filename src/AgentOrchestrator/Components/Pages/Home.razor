@page "/"
@using GitHub.Copilot
@using System.Text.Json
@using Markdig
@using Microsoft.JSInterop
@implements IDisposable
@inject AppState AppState
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>AgentOrchestrator</PageTitle>

<div class="flex h-screen overflow-hidden font-sans">
    @* Pipeline panel *@
    <div class="flex-1 px-8 pt-3 overflow-y-auto relative"
         style="background-color: #17171b;
                background-image: radial-gradient(rgba(255,255,255,0.10) 1px, transparent 1px);
                background-size: 20px 20px;">

        @* Add enquiry button *@
        <div class="absolute top-3 right-8 inline-block z-40">
            <button class="flex items-center justify-center w-10 h-10 bg-zinc-900 hover:bg-zinc-800 text-zinc-300 rounded-md border border-zinc-700 cursor-pointer transition-colors"
                    @onclick="ToggleAddMenu">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
            </button>
            @if (_showAddMenu)
            {
                <div class="absolute right-0 top-full mt-1 w-[28rem] bg-zinc-900 rounded-md shadow-xl border border-zinc-700 py-1 max-h-96 overflow-y-auto">
                    <div class="px-3 py-2 text-sm font-medium text-zinc-500">Sample enquiries</div>
                    @foreach (var enquiry in SampleEnquiries)
                    {
                        <button class="w-full text-left px-3 py-2 text-lg text-zinc-300 hover:bg-zinc-800 cursor-pointer leading-snug"
                                @onclick="() => SubmitEnquiry(enquiry)">
                            @enquiry
                        </button>
                    }
                </div>
            }
        </div>

        <div class="relative" style="height: @(MaxRowCount * RowHeight)px">
            @* Flow lines + arrowheads *@
            <svg class="absolute inset-0 pointer-events-none z-0" style="width: 100%; height: 100%; overflow: visible">
                <defs>
                    <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5"
                            markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                        <path d="M 0 0 L 10 5 L 0 10 z" fill="#a1a1aa" />
                    </marker>
                </defs>
                @foreach (var edge in PipelineConfig.Edges)
                {
                    var from = PipelineConfig.Nodes[edge.From];
                    var to = PipelineConfig.Nodes[edge.To];
                    var fromX = from.Col * ColWidth + ColOffset;
                    var toX   = to.Col   * ColWidth + ColOffset;
                    var fromY = from.Row * RowHeight + from.YOffset;
                    var toY   = to.Row   * RowHeight + to.YOffset;

                    if (from.Col == to.Col)
                    {
                        var cx = fromX + CardWidth / 2;
                        var y1 = fromY + CardHeight;
                        var y2 = toY - 2;
                        <line x1="@cx" y1="@y1" x2="@cx" y2="@y2"
                              stroke="#a1a1aa" stroke-width="2" stroke-linecap="round"
                              marker-end="url(#arrow)" />
                    }
                    else
                    {
                        var srcIsLeft = from.Col < to.Col;
                        var x1 = srcIsLeft ? fromX + CardWidth : fromX;
                        var x2 = srcIsLeft ? toX - 2          : toX + CardWidth + 2;
                        var y1 = fromY + CardHeight / 2;
                        var y2 = toY + CardHeight / 2;
                        <line x1="@x1" y1="@y1" x2="@x2" y2="@y2"
                              stroke="#a1a1aa" stroke-width="2" stroke-linecap="round"
                              marker-end="url(#arrow)" />
                    }
                }
            </svg>

            @* Phase cards *@
            @foreach (var (phase, node) in PipelineConfig.Nodes)
            {
                var x = node.Col * ColWidth + ColOffset;
                var y = node.Row * RowHeight + node.YOffset;
                var isRejected = node.IsFinished && phase != Phase.Done;
                var isDone = phase == Phase.Done;

                <div class="absolute z-10 rounded-lg border flex shadow-[inset_0_1px_0_0_rgba(255,255,255,0.04),_0_10px_28px_-8px_rgba(0,0,0,0.55)]
                            @(isDone     ? "border-emerald-400/60" :
                              isRejected ? "border-rose-400/60" :
                                           "border-zinc-700")"
                     style="left: @(x)px; top: @(y)px; width: @(CardWidth)px; height: @(CardHeight)px; background: linear-gradient(180deg, #26262b 0%, #222227 60%, #1f1f24 100%);">
                    <div class="shrink-0 pl-5 pt-4"
                         style="width: @(HeaderColWidth)px">
                        <h3 class="text-2xl font-medium tracking-tight leading-snug
                                   @(isDone ? "text-emerald-400" :
                                     isRejected ? "text-rose-400" :
                                     "text-zinc-100")">
                            @node.Label
                        </h3>
                    </div>
                </div>
            }

            @* Agent rows: absolutely positioned, animate between cards *@
            @foreach (var agent in GetAllAgents())
            {
                var node = PipelineConfig.Nodes[agent.Phase];
                var agentsAtPhase = GetAgentsAtPhase(agent.Phase);
                var stackIndex = agentsAtPhase.IndexOf(agent);
                if (stackIndex < 0) stackIndex = 0;
                var cardX = node.Col * ColWidth + ColOffset;
                var cardY = node.Row * RowHeight + node.YOffset;
                var x = cardX + HeaderColWidth + ChipPadX;
                var y = cardY + BodyPadY + stackIndex * ChipHeight;
                var isSelected = agent.Id == _selectedAgentId;
                var isRejected = node.IsFinished && agent.Phase != Phase.Done;
                var isDone = agent.Phase == Phase.Done;

                var isFading = IsFinished(agent) && agent.Phase != Phase.Done
                    && agent.FinishedAt.HasValue
                    && (DateTime.UtcNow - agent.FinishedAt.Value).TotalSeconds > 12;

                var isBusy = !IsFinished(agent);
                var dotColor   = isDone     ? "text-emerald-400" :
                                 isRejected ? "text-rose-400" :
                                              "text-amber-300";
                var titleColor = isSelected ? "text-indigo-300" :
                                 isDone     ? "text-emerald-400" :
                                 isRejected ? "text-rose-400" :
                                              "text-zinc-100";

                <button @key="agent.Id"
                        class="absolute z-20 flex flex-col justify-start cursor-pointer text-left rounded-md pl-4 pr-5 pt-2.5 pb-2
                               @(isSelected ? "bg-indigo-500/20 hover:bg-indigo-500/25 ring-1 ring-indigo-400" :
                                 "bg-zinc-700 hover:bg-zinc-600")"
                        style="top: @(y)px; left: @(x)px; width: @(ChipWidth)px; height: @(ChipHeight - 4)px; opacity: @(isFading ? "0" : "1"); transition: top 0.7s cubic-bezier(0.76, 0, 0.24, 1), left 0.7s cubic-bezier(0.76, 0, 0.24, 1), opacity @(isFading ? "2s ease-in" : "0.3s"), background-color 0.15s"
                        @onclick="() => SelectAgent(agent.Id)">
                    <div class="flex items-center gap-2.5 min-w-0">
                        <span class="relative inline-flex h-3 w-3 shrink-0 @dotColor">
                            @if (isBusy)
                            {
                                <span class="absolute inset-0 rounded-full bg-current agent-throb"></span>
                            }
                            <span class="relative inline-block h-3 w-3 rounded-full bg-current"></span>
                        </span>
                        <span class="text-xl font-normal truncate leading-snug @titleColor">@agent.Enquiry</span>
                    </div>
                    <div class="text-lg text-zinc-400 truncate leading-snug mt-1.5 ml-[22px]">
                        @agent.CurrentIntent
                    </div>
                </button>
            }
        </div>
    </div>

    @* Sidebar — always visible *@
    <div @ref="_sidebar" class="w-[28rem] bg-white p-7 overflow-y-auto shadow-[-8px_0_30px_-4px_rgba(0,0,0,0.15)] z-30">
        @if (_selectedAgent is not null)
        {
            var sNode = PipelineConfig.Nodes[_selectedAgent.Phase];
            var sIsRejected = sNode.IsFinished && _selectedAgent.Phase != Phase.Done;
            var errorEvent = _selectedAgent.SessionEvents.OfType<SessionErrorEvent>().LastOrDefault();

            <div class="flex items-center justify-between mb-6">
                <h3 class="text-base font-semibold tracking-widest uppercase text-slate-400">Agent Details</h3>
                <button class="text-slate-300 hover:text-slate-500 transition-colors cursor-pointer" @onclick="DeselectAgent">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
            <dl class="space-y-5">
                <div>
                    <dt class="text-sm uppercase tracking-wider text-slate-400">ID</dt>
                    <dd class="mt-1.5 text-xl"><code class="bg-slate-100 px-2.5 py-1 rounded text-lg text-slate-600 font-mono">@_selectedAgent.Id</code></dd>
                </div>
                <div>
                    <dt class="text-sm uppercase tracking-wider text-slate-400">Description</dt>
                    <dd class="mt-1.5 text-xl text-slate-700 leading-relaxed">@_selectedAgent.Enquiry</dd>
                </div>
                <div>
                    <dt class="text-sm uppercase tracking-wider text-slate-400">Phase</dt>
                    <dd class="mt-1.5 text-xl">
                        <span class="inline-flex items-center px-4 py-2 rounded-full text-lg font-medium
                                     @(_selectedAgent.Phase == Phase.Done ? "bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200" :
                                       sIsRejected ? "bg-red-50 text-red-700 ring-1 ring-red-200" :
                                       "bg-indigo-50 text-indigo-700 ring-1 ring-indigo-200")">
                            @sNode.Label
                        </span>
                    </dd>
                </div>
                <div>
                    <dt class="text-sm uppercase tracking-wider text-slate-400">Started</dt>
                    <dd class="mt-1.5 text-xl text-slate-700">@FormatElapsed(_selectedAgent.StartedAt)</dd>
                </div>
            </dl>

            @if (errorEvent is not null)
            {
                <div class="mt-5 bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-lg text-red-700 leading-relaxed">
                    <span class="font-semibold">Error:</span> @errorEvent.Data.Message
                </div>
            }

            @if (_selectedAgent.SessionEvents.Count > 0)
            {
                var completions = _selectedAgent.SessionEvents
                    .OfType<ToolExecutionCompleteEvent>()
                    .ToDictionary(c => c.Data.ToolCallId, c => c);

                <div class="mt-7">
                    <dt class="text-sm uppercase tracking-wider text-slate-400 mb-3">Session Log</dt>
                    <div class="space-y-2">
                        @foreach (var evt in _selectedAgent.SessionEvents)
                        {
                            if (evt is AssistantMessageEvent ame)
                            {
                                if (!string.IsNullOrWhiteSpace(ame.Data.Content))
                                {
                                    <div @key="@ame.Id" class="px-1 py-1 text-xl text-slate-700 leading-relaxed prose prose-lg prose-slate max-w-none">
                                        @((MarkupString)Markdown.ToHtml(ame.Data.Content, _markdownPipeline))
                                    </div>
                                }
                                if (ame.Data.ToolRequests is { Length: > 0 } toolRequests)
                                {
                                    foreach (var tr in toolRequests)
                                    {
                                        completions.TryGetValue(tr.ToolCallId, out var completion);
                                        <ToolCallView @key="@($"{ame.Id}-{tr.ToolCallId}")" Request="tr" Completion="completion" />
                                    }
                                }
                            }
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <h3 class="text-base font-semibold tracking-widest uppercase text-slate-400 mb-6">Dashboard</h3>
            <div class="space-y-4">
                <div class="flex items-center gap-5 bg-slate-50 rounded-xl p-5 border border-slate-100">
                    <div class="w-2 h-16 rounded-full bg-indigo-400"></div>
                    <div>
                        <div class="text-5xl font-bold text-slate-800">@GetActiveCount()</div>
                        <div class="text-xl text-slate-400 mt-1">Processing</div>
                    </div>
                </div>
                <div class="flex items-center gap-5 bg-slate-50 rounded-xl p-5 border border-slate-100">
                    <div class="w-2 h-16 rounded-full bg-emerald-400"></div>
                    <div>
                        <div class="text-5xl font-bold text-slate-800">@GetDoneCount()</div>
                        <div class="text-xl text-slate-400 mt-1">Completed</div>
                    </div>
                </div>
                <div class="flex items-center gap-5 bg-slate-50 rounded-xl p-5 border border-slate-100">
                    <div class="w-2 h-16 rounded-full bg-red-400"></div>
                    <div>
                        <div class="text-5xl font-bold text-slate-800">@GetRejectedCount()</div>
                        <div class="text-xl text-slate-400 mt-1">Rejected</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private static readonly MarkdownPipeline _markdownPipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    // Landscape card layout — title column on the left, agents fill the right.
    private const int CardWidth       = 462;
    private const int CardHeight      = 200;
    private const int HeaderColWidth  = 147;
    private const int ColWidth        = 516;   // 462 + 54 gap
    private const int RowHeight       = 240;   // 200 + 40 gap
    private const int ColOffset       = 0;

    private const int BodyPadY    = 16;
    private const int ChipHeight  = 84;   // 2 lines: text-xl + text-lg with comfortable padding
    private const int ChipPadX    = 12;
    private const int ChipWidth   = CardWidth - HeaderColWidth - ChipPadX * 2;

    private int MaxRowCount => PipelineConfig.Nodes.Values.Max(n => n.Row) + 1;

    private ElementReference _sidebar;
    private bool _sidebarAutoScrollSetup;

    private string? _selectedAgentId;
    private bool _showAddMenu;
    private Agent? _selectedAgent => _selectedAgentId is not null && AppState.Agents.TryGetValue(_selectedAgentId, out var agent) ? agent : null;

    private static readonly string[] SampleEnquiries =
    [
        "Looking for a 3-bed family home near good schools in the suburbs, budget around $500k",
        "Need a downtown condo with parking, 1-2 bedrooms, under $350k",
        "Seeking waterfront property with at least 4 bedrooms for retirement",
        "Budget max $450k, want to be near Sugar Wharf Podium School",
        "Want a rural property with land, at least 5 acres, horse-friendly",
        "asdkjh asdkjhasd this is spam garbage text!!!",
        "Investor looking for multi-unit rental property near university campus",
        "Need an accessible single-story home with wheelchair modifications, 2+ bed",
        "Looking for a fixer-upper Victorian in the historic district",
        "BUY CRYPTO NOW!!! Not actually looking for property lol",
    ];

    protected override void OnInitialized()
    {
        AppState.UpdateUi += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_sidebarAutoScrollSetup)
        {
            _sidebarAutoScrollSetup = true;
            await JS.InvokeVoidAsync("setupAutoScrollEnd", _sidebar);
        }
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void SelectAgent(string id)
    {
        _selectedAgentId = id;
    }

    private void DeselectAgent()
    {
        _selectedAgentId = null;
    }

    private void ToggleAddMenu()
    {
        _showAddMenu = !_showAddMenu;
    }

    private void SubmitEnquiry(string enquiry)
    {
        _showAddMenu = false;
        _ = AppState.RunAgentAsync(enquiry);
    }

    private List<Agent> GetAllAgents()
    {
        return AppState.Agents.Values.OrderBy(a => a.Id).ToList();
    }

    private List<Agent> GetAgentsAtPhase(Phase phase)
    {
        return AppState.Agents.Values
            .Where(a => a.Phase == phase)
            .OrderBy(a => a.StartedAt)
            .ThenBy(a => a.Id)
            .ToList();
    }

    private static string FormatElapsed(DateTime startedAt)
    {
        var elapsed = DateTime.UtcNow - startedAt;
        if (elapsed.TotalSeconds < 60) return $"{(int)elapsed.TotalSeconds}s ago";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m ago";
        return $"{(int)elapsed.TotalHours}h ago";
    }

    private int GetActiveCount() => AppState.Agents.Values.Count(a => !IsFinished(a));
    private int GetDoneCount() => AppState.Agents.Values.Count(a => a.Phase == Phase.Done);
    private int GetRejectedCount() => AppState.Agents.Values.Count(a => IsFinished(a) && a.Phase != Phase.Done);

    private static bool IsFinished(Agent agent)
    {
        return PipelineConfig.Nodes[agent.Phase].IsFinished;
    }

    private static bool HasPendingToolCall(Agent agent)
    {
        var completed = new HashSet<string>(StringComparer.Ordinal);
        foreach (var evt in agent.SessionEvents)
        {
            if (evt is ToolExecutionCompleteEvent tec)
                completed.Add(tec.Data.ToolCallId);
        }
        foreach (var evt in agent.SessionEvents)
        {
            if (evt is AssistantMessageEvent ame && ame.Data.ToolRequests is { Length: > 0 } reqs)
            {
                foreach (var r in reqs)
                {
                    if (!completed.Contains(r.ToolCallId)) return true;
                }
            }
        }
        return false;
    }

    public void Dispose()
    {
        AppState.UpdateUi -= OnStateChanged;
    }
}
