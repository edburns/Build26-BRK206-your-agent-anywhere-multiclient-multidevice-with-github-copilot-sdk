<?xml version="1.0" encoding="UTF-8"?>
<server description="Spike: Jakarta Data + H2 in-memory on Liberty 26.0.0.5">

    <featureManager>
        <feature>data-1.0</feature>
        <feature>persistence-3.2</feature>
        <feature>faces-4.1</feature>
        <feature>cdi-4.1</feature>
    </featureManager>

    <httpEndpoint id="defaultHttpEndpoint"
                  httpPort="${default.http.port}"
                  httpsPort="9443" />

    <!-- H2 JDBC driver shared library -->
    <library id="h2Lib">
        <fileset dir="${server.config.dir}/jdbc" includes="h2*.jar" />
    </library>

    <!-- H2 in-memory datasource -->
    <dataSource id="DefaultDataSource" jndiName="jdbc/defaultDS">
        <jdbcDriver libraryRef="h2Lib" />
        <properties URL="jdbc:h2:mem:spikedb;DB_CLOSE_DELAY=-1" />
    </dataSource>

    <webApplication location="phase-02-2.5-h2-in-memory-jakarta-data.war" contextRoot="/" />

</server>
